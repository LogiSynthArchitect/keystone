<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash background for pre-API 21 devices (very old Android).
  Vectors are not supported in layer-list bitmaps before API 21,
  so we fall back to the raster PNG splash image.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid dark navy background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A1628"/>
        </shape>
    </item>
    <!-- PNG fallback logo -->
    <item>
        <bitmap android:gravity="center" android:src="@drawable/splash"/>
    </item>
</layer-list>
