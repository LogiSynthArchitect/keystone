<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash background for API 21-30.
  Uses the XML vector drawable directly — no bitmap needed on API 21+.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid dark navy background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A1628"/>
        </shape>
    </item>
    <!-- Keystone vector logo centered -->
    <item
        android:gravity="center"
        android:drawable="@drawable/ic_keystone_splash_logo"/>
</layer-list>
